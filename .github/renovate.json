{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    "group:allNonMajor",
    ":enableVulnerabilityAlerts"
  ],
  "labels": [
    "Meta: Dependencies"
  ],
  "schedule": [
    "before 12pm on Sunday"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "matchJsonata": [
        "$exists(vulnerabilityFixVersion)"
      ],
      "labels": [
        "security"
      ],
      "automerge": false
    }
  ],
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "labels": [
      "security"
    ],
    "automerge": false,
    "vulnerabilityFixStrategy": "lowest"
  }
}
